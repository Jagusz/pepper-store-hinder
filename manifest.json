{
  "manifest_version": 2,
  "name": "Filtr sklepów dla Pepper.pl",
  "version": "0.2.0",
  "description": "Nieoficjalne rozszerzenie do ukrywania ofert z wybranych sklepów na Pepper.pl. Lista filtrów może być synchronizowana przez Firefox Sync.",
  "permissions": [
    "storage",
    "https://www.pepper.pl/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.pepper.pl/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "browser_action": {
    "default_title": "Filtr sklepów dla Pepper.pl",
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "filtr-sklepow-pepper@example.local",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    },
    "gecko_android": {}
  }
}
