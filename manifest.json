{
  "manifest_version": 2,
  "name": "Deal Store Filter",
  "version": "0.2.0",
  "description": "Hide deals from selected stores on supported shopping and deal websites. Filters can be synchronized with Firefox Sync.",
  "permissions": [
    "storage",
    "https://www.pepper.pl/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.pepper.pl/*"
      ],
      "js": [
        "i18n.js",
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "browser_action": {
    "default_title": "Deal Store Filter",
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "deal-store-filter@example.local",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    },
    "gecko_android": {}
  }
}
